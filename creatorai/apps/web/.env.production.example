# ── CreatorAI Web — PRODUCTION env (set these in the Vercel dashboard) ──
# These are baked into the build (Vite inlines VITE_* at build time), so a redeploy
# is needed after changing them. They are PUBLIC (shipped to the browser) — only put
# publishable values here, never secrets.

# Your deployed API (Railway) URL — no trailing slash.
VITE_API_URL=https://YOUR-API-DOMAIN

# Supabase (Project Settings → API) — the anon key is safe to expose.
VITE_SUPABASE_URL=https://YOUR-REF.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR-ANON-KEY
