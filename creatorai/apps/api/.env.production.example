# ── CreatorAI API — PRODUCTION env (set these in the Railway dashboard) ──
# Copy values from the services below. NEVER commit real values.

# Node
NODE_ENV=production
# PORT is injected by Railway automatically — do NOT set it yourself.

# ── Database: Supabase Postgres ──
# Use the DIRECT connection string (host db.<ref>.supabase.co, port 5432) so that
# `prisma migrate deploy` works on deploy. Found in Supabase → Project Settings →
# Database → Connection string → "URI" (not the pooled 6543 one).
DATABASE_URL=postgresql://postgres:YOUR-DB-PASSWORD@db.YOUR-REF.supabase.co:5432/postgres

# ── Redis: Upstash ──
# Upstash → your database → "Redis" connection → rediss:// URL (TLS).
REDIS_URL=rediss://default:YOUR-UPSTASH-PASSWORD@YOUR-ENDPOINT.upstash.io:6379

# ── Supabase Auth ── (Project Settings → API)
SUPABASE_URL=https://YOUR-REF.supabase.co
SUPABASE_ANON_KEY=YOUR-ANON-KEY
SUPABASE_SERVICE_KEY=YOUR-SERVICE-ROLE-KEY

# ── Stripe (LIVE keys once your account is activated; sk_test_ is fine to launch in test) ──
STRIPE_SECRET_KEY=sk_live_or_test_KEY
# From the webhook endpoint you create in the Stripe Dashboard pointing at
# https://YOUR-API-DOMAIN/payments/stripe/webhook
STRIPE_WEBHOOK_SECRET=whsec_FROM_DASHBOARD_ENDPOINT

# ── URLs ── (your deployed web app)
WEB_URL=https://YOUR-WEB-DOMAIN
CORS_ORIGINS=https://YOUR-WEB-DOMAIN

# ── AI providers (optional — only needed for premium/video/3D/editing tools) ──
REPLICATE_API_TOKEN=

# ── Storage: Cloudflare R2 (optional — falls back to provider URLs if unset) ──
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=creatorai-uploads
R2_PUBLIC_URL=
