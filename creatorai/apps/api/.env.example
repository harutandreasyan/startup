# Database (matches docker-compose.yml)
DATABASE_URL=postgresql://creator:creator_dev@localhost:5432/creatorai

# Redis (matches docker-compose.yml)
REDIS_URL=redis://localhost:6379

# Supabase Auth — get from supabase.com project settings → API
SUPABASE_URL=https://xxx.supabase.co
SUPABASE_ANON_KEY=xxx
SUPABASE_SERVICE_KEY=xxx

# AI Providers — get from replicate.com/account/api-tokens
REPLICATE_API_TOKEN=r8_xxx

# Storage (Cloudflare R2) — optional for local dev; falls back to provider URLs
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=creatorai-uploads
R2_PUBLIC_URL=

# Stripe — get from dashboard.stripe.com (use TEST mode keys for dev)
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx

# App
PORT=3000
NODE_ENV=development
CORS_ORIGINS=http://localhost:5180
WEB_URL=http://localhost:5180
